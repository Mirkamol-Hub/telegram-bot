# ════════════════════════════════════════════════
# Learning Center ERP+CRM — Environment Variables
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════

# ── Telegram Bot ─────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The public HTTPS URL of your deployed app + /webhook
# e.g. https://your-app.onrender.com/webhook
WEBHOOK_URL=https://your-app.onrender.com/webhook

# Public URL where the Mini App is served (same as your app root)
MINI_APP_URL=https://your-app.onrender.com

# ── Google Sheets ─────────────────────────────────
# ID from your Google Spreadsheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Option A: Paste the full service account JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option B: Path to service account JSON file (for local dev)
# GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ── Roles (comma-separated Telegram user IDs) ──────
# Get your Telegram ID from @userinfobot
ADMIN_IDS=123456789,987654321
TEACHER_IDS=111222333,444555666

# ── Development ────────────────────────────────────
# Set to "true" to bypass Telegram signature verification locally
DEV_MODE=false

# ── Server ─────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
